{
  "name": "local-explorer",
  "version": "1.0.0",
  "type": "module",
  "description": "A Progressive Web App for discovering local attractions, events, and activities",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node netlify/inject-env.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
    "verify": "npm run check && node verify-api-functions.cjs"
  },
  "keywords": [
    "pwa",
    "local",
    "explorer",
    "travel",
    "events"
  ],
  "author": "guySteve",
  "license": "MIT",
  "devDependencies": {
    "@babel/generator": "^7.29.7",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "svelte": "^4.2.20",
    "svelte-adapter-azure-swa": "^0.22.1",
    "svelte-check": "^3.8.6",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.1.0",
    "workbox-build": "^7.4.1",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-svelte": "^0.395.0",
    "openai": "^4.28.0"
  }
}
